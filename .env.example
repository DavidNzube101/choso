# Nosana Qwen3.5 inference endpoint (get from nosana.com/builders-credits)
OPENAI_API_KEY=nosana
OPENAI_API_BASE_URL=https://YOUR_NOSANA_ENDPOINT/v1

# Telegram bot token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# SQLite database path
SQLITE_DB_PATH=./data/choso.db

# Server port (used by Nosana health check)
SERVER_PORT=3000
